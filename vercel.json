{
  "version": 2,
  "builds": [
    {
      "src": "api/resolve.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/progress.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/resolve",
      "dest": "/api/resolve.js"
    },
    {
      "src": "/api/progress",
      "dest": "/api/progress.js"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
